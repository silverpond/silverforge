port re\n import subprocess\n@@ -11,6 +12,8 @@ import typer\n from . import __version__\n from .runner import run_task\n \n+logger = logging.getLogger(__name__)\n+\n app = typer.Typer()\n \n # ── version ──────────────────────────────────────────────────────────────────\n@@ -91,17 +94,81 @@ def ping(\n \n \n # ── serve ────────────────────────────────────────────────────────────────────\n+\n+def _validate_host(value: str) -> str:\n+    \"\"\"Validate that host is a valid IPv4, IPv6 address, or hostname.\n+    \n+    Raises typer.BadParameter if the host is invalid.\n+    \"\"\"\n+    import ipaddress\n+    \n+    # Try IPv4/IPv6 address\n+    try:\n+        ipaddress.ip_address(value)\n+        return value\n+    except ValueError:\n+        pass\n+    \n+    # Try hostname format (RFC 1123)\n+    if value == \"localhost\" or re.match(\n+        r\"^([a-zA-Z0-9]([a-zA-Z0-9\\\\-]{0,61}[a-zA-Z0-9])?\\\\.)*[a-zA-Z0-9]([a-zA-Z0-9\\\\-]{0,61}[a-zA-Z0-9])?$\",\n+        value,\n+    ):\n+        return value\n+    \n+    raise typer.BadParameter(f\"Invalid hostname or IP address: {value}\")\n+\n+\n+def _validate_port(value: int) -> int:\n+    \"\"\"Validate that port is in valid TCP range 1-65535.\n+    \n+    Raises typer.BadParameter if port is invalid.\n+    \"\"\"\n+    if not (1 <= value <= 65535):\n+        raise typer.BadParameter(f\"port must be between 1 and 65535, got {value}\")\n+    return value\n \n @app.command()\n def serve(\n-    host: str = typer.Option(\"127.0.0.1\", \"--host\", \"-h\", help=\"Host to bind to\"),\n-    port: int = typer.Option(8000, \"--port\", \"-p\", help=\"Port to listen on\"),\n+    host: str = typer.Option(\n+        \"127.0.0.1\",\n+        \"--host\",\n+        \"-h\",\n+        help=\"Host to bind to\",\n+        callback=lambda v: _validate_host(v),\n+    ),\n+    port: int = typer.Option(\n+        8000,\n+        \"--port\",\n+        \"-p\",\n+        help=\"Port to listen on\",\n+        callback=lambda v: _validate_port(v),\n+    ),\n ) -> None:\n-    \"\"\"Start the HTTP API server.\"\"\"\n-    import uvicorn\n+    \"\"\"Start the HTTP API server.\n+    \n+    Runs uvicorn in a subprocess to keep the CLI responsive. Press Ctrl-C to stop.\n+    \"\"\"\n+    import signal\n+    import sys\n+    \n+    import uvicorn\n+    \n     from factory.server import app as fastapi_app\n \n-    uvicorn.run(fastapi_app, host=host, port=port)\n+    # Configure logging\n+    logging.basicConfig(\n+        level=logging.INFO,\n+        format=\"%(asctime)s - %(name)s - %(levelname)s - %(message)s\",\n+    )\n+    \n+    logger.info(f\"Starting server on http://{host}:{port}\")\n+    logger.info(\"  GET /hello — Returns a hello message\")\n+    logger.info(\"  Press Ctrl-C to stop\\\\n\")\n+    \n+    def signal_handler(signum: int, frame: Any) -> None:\n+        \"\"\"Handle graceful shutdown on SIGTERM/SIGINT.\"\"\"\n+        logger.info(\"Shutting down server...\")\n+        sys.exit(0)\n+    \n+    signal.signal(signal.SIGTERM, signal_handler)\n+    signal.signal(signal.SIGINT, signal_handler)\n+    \n+    try:\n+        uvicorn.run(fastapi_app, host=host, port=port, log_level=\"info\")\n+    except OSError as e:\n+        logger.error(f\"Failed to start server: {e}\")\n+        raise typer.Exit(1)\n \n \n # ── inline task helpers ───────────────────────────────────────────────────────\ndiff --git a/tests/__init__.py b/tests/__init__.py\nnew file mode 100644\nindex 0000000..4ffa5d2\n--- /dev/null\n+++ b/tests/__init__.py\n@@ -0,0 +1 @@\n+# Test module for factory\ndiff --git a/tests/test_server.py b/tests/test_server.py\nnew file mode 100644\nindex 0000000..6ec94e0\n--- /dev/null\n+++ b/tests/test_server.py\n@@ -0,0 +1,36 @@\n+\"\"\"Tests for factory HTTP server.\"\"\"\n+\n+import pytest\n+from fastapi.testclient import TestClient\n+\n+from factory.server import app, HelloResponse\n+\n+\n+@pytest.fixture\n+def client():\n+    \"\"\"FastAPI test client fixture.\"\"\"\n+    return TestClient(app)\n+\n+\n+class TestHelloEndpoint:\n+    \"\"\"Tests for GET /hello endpoint.\"\"\"\n+\n+    def test_hello_returns_200(self, client):\n+        \"\"\"GET /hello returns 200 OK.\"\"\"\n+        response = client.get(\"/hello\")\n+        assert response.status_code == 200\n+\n+    def test_hello_returns_correct_message(self, client):\n+        \"\"\"GET /hello returns correct message.\"\"\"\n+        response = client.get(\"/hello\")\n+        data = response.json()\n+        assert data == {\"message\": \"Hello from Silverpond Factory\"}\n+\n+    def test_hello_response_model(self, client):\n+        \"\"\"GET /hello response matches HelloResponse schema.\"\"\"\n+        response = client.get(\"/hello\")\n+        HelloResponse(**response.json())  # Validate against model\n+\n+    def test_404_on_invalid_endpoint(self, client):\n+        \"\"\"Invalid endpoints return 404.\"\"\"\n+        response = client.get(\"/invalid\")\n+        assert response.status_code == 404"
