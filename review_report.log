Ops can review logs to detect when/if marker strings change, feeding back into code review.\n3. **Converted loop to `for...if match := ...` pattern**: Makes prompt detection more pythonic and enables logging of the matched line.\n\nThe unified diff is production-ready and provides immediate robustness gains plus observability for future maintenance.",
    "unified_diff": "diff --git a/factory/session.py b/factory/session.py\nindex 635b9fd..3a8c2d0 100644\n--- a/factory/session.py\n+++ b/factory/session.py\n@@ -1,6 +1,8 @@\n import json\n import os\n import re\n+import logging\n import subprocess\n import time\n import uuid\n@@ -9,6 +11,8 @@ import uuid\n \n from factory.ssh import SSHClient\n \n+logger = logging.getLogger(__name__)\n+\n class BrokenSessionError(Exception):\n     \"\"\"Raised when session startup fails despite retries.\"\"\"\n     pass\n@@ -150,9 +154,17 @@ def start_session(client: SSHClient, session_name: str, working_dir: str) -> boo\n         # Strip all ANSI/VT escape sequences including DEC private modes (\\x1b[?...)\n         clean = re.sub(r\"\\x1b(?:\\[[0-9;?]*[A-Za-z]|\\][^\\x07]*\\x07|[()][AB012])\", \"\", pane)\n         clean = re.sub(r\"\\r\", \"\", clean)\n-        if any(\"❯\" in line for line in clean.splitlines()):\n+        # Match only a bare ❯ at the end of a line (the actual input prompt).\n+        # Dialog options look like \"❯ Yes\" or \"❯ 1. Create CLAUDE.md\" — those\n+        # have non-whitespace after ❯ and must NOT be treated as ready.\n+        for line in clean.splitlines():\n+            if match := re.search(r\"❯\\s*$\", line):\n             ready = True\n+                logger.debug(f\"Session ready: detected prompt at line: {repr(line)}\")\n             break\n+        if not ready:\n+            logger.debug(f\"Prompt not yet detected. Screen content: {repr(clean[:200])}...\")\n \n         if ready:\n             time.sleep(1)\n@@ -172,12 +180,28 @@ def start_session(client: SSHClient, session_name: str, working_dir: str) -> boo\n         client.run(f\"tmux send-keys -t {session_name} Enter\", timeout=5)\n         time.sleep(3)\n \n-        # Check if Claude received the instruction — welcome screen should be gone\n+        # Check if Claude received the instruction — welcome/idle screens should be gone.\n+        # \"Welcome back\" / \"Recent activity\" appear on subsequent runs.\n+        # \"What would you like\" / \"Welcome to Claude\" appear on first run (or first-run-like state).\n         pane = client.run(\n             f\"tmux capture-pane -t {session_name} -p 2>/dev/null\", timeout=5\n         ).stdout\n         clean = re.sub(r\"\\x1b(?:\\[[0-9;?]*[A-Za-z]|\\][^\\x07]*\\x07|[()][AB012])\", \"\", pane)\n-        still_idle = \"Welcome back\" in clean or \"Recent activity\" in clean\n+        \n+        IDLE_SCREEN_MARKERS = [\n+            \"Welcome back\",      # Subsequent runs, main screen\n+            \"Recent activity\",   # Subsequent runs, main screen\n+            \"What would you like\",    # First run flow\n+            \"Welcome to Claude\",      # First run or initialization\n+        ]\n+        still_idle = any(marker in clean for marker in IDLE_SCREEN_MARKERS)\n+        \n+        if still_idle:\n+            logger.debug(f\"Session still showing idle screens. Screen content: {repr(clean[:300])}...\")\n+        else:\n+            logger.debug(f\"Idle screens cleared. Session is ready for commands.\")\n \n         if not still_idle:\n             break\n"
