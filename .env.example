# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Required: GitHub personal access token
# Needs scopes: repo, issues, pull_requests, workflows
# Create at: https://github.com/settings/tokens
FACTORY_GITHUB_TOKEN=ghp_your_token_here

# Optional: command that prints a fresh GitHub token to stdout.
# If set, it is run on demand whenever a token is needed and takes precedence
# over FACTORY_GITHUB_TOKEN — use it with short-lived GitHub App installation
# tokens (which expire hourly) so the factory keeps working over long runs.
# FACTORY_GITHUB_TOKEN_CMD=/path/to/gh-app-token

# Required: your Unix username on the worker machine (ares)
# Set automatically by 'factory setup'
FACTORY_WORKER_USER=yourname

# Required: path to your SSH private key for connecting to the worker machine
# Set automatically by 'factory setup'
FACTORY_SSH_IDENTITY=~/.ssh/id_ed25519

# Optional: Slack tokens for run notifications — ask your admin for these
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_APP_TOKEN=xapp-your-token-here
