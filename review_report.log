m fastapi.testclient import TestClient\n+\n+from factory.server import app\n+\n+\n+client = TestClient(app)\n+\n+\n+def test_hello_endpoint_returns_json():\n+    \"\"\"Test that /hello returns valid JSON response.\"\"\"\n+    response = client.get(\"/hello\")\n+    assert response.status_code == 200\n+    assert response.json() == {\"message\": \"hello\"}\n+\n+\n+def test_hello_endpoint_content_type():\n+    \"\"\"Test that /hello returns correct content type.\"\"\"\n+    response = client.get(\"/hello\")\n+    assert response.headers[\"content-type\"] == \"application/json\"\n+\n+\n+def test_hello_endpoint_post_not_allowed():\n+    \"\"\"Test that /hello rejects POST requests.\"\"\"\n+    response = client.post(\"/hello\")\n+    assert response.status_code == 405  # Method Not Allowed\n+\n+\n+def test_hello_endpoint_put_not_allowed():\n+    \"\"\"Test that /hello rejects PUT requests.\"\"\"\n+    response = client.put(\"/hello\")\n+    assert response.status_code == 405\n+\n+\n+def test_404_for_nonexistent_endpoint():\n+    \"\"\"Test that nonexistent endpoints return 404.\"\"\"\n+    response = client.get(\"/nonexistent\")\n+    assert response.status_code == 404\ndiff --git a/tests/test_cli_serve.py b/tests/test_cli_serve.py\nnew file mode 100644\nindex 0000000..2345678\n--- /dev/null\n+++ b/tests/test_cli_serve.py\n@@ -0,0 +1,67 @@\n+\"\"\"Tests for the serve CLI command.\"\"\"\n+from unittest.mock import patch, MagicMock\n+\n+import pytest\n+from typer.testing import CliRunner\n+\n+from factory.cli import app\n+\n+\n+runner = CliRunner()\n+\n+\n+def test_serve_port_validation_negative():\n+    \"\"\"Test that negative port numbers are rejected.\"\"\"\n+    result = runner.invoke(app, [\"serve\", \"--port\", \"-1\"])\n+    assert result.exit_code == 1\n+    assert \"Port must be between 0 and 65535\" in result.output\n+\n+\n+def test_serve_port_validation_too_high():\n+    \"\"\"Test that port numbers above 65535 are rejected.\"\"\"\n+    result = runner.invoke(app, [\"serve\", \"--port\", \"65536\"])\n+    assert result.exit_code == 1\n+    assert \"Port must be between 0 and 65535\" in result.output\n+\n+\n+def test_serve_port_zero_valid():\n+    \"\"\"Test that port 0 (OS-assigned dynamic port) passes validation.\"\"\"\n+    # Port 0 should pass validation (negative check fails for 0)\n+    # But we can't actually start the server, so we mock uvicorn.run\n+    with patch('uvicorn.run'):\n+        result = runner.invoke(app, [\"serve\", \"--port\", \"0\"])\n+        # Should not fail validation\n+        assert \"Port must be between 0 and 65535\" not in result.output\n+\n+\n+def test_serve_port_max_valid():\n+    \"\"\"Test that port 65535 (max valid port) passes validation.\"\"\"\n+    with patch('uvicorn.run'):\n+        result = runner.invoke(app, [\"serve\", \"--port\", \"65535\"])\n+        assert \"Port must be between 0 and 65535\" not in result.output\n+\n+\n+@patch('uvicorn.run')\n+def test_serve_default_host_and_port(mock_run):\n+    \"\"\"Test that default host and port are used.\"\"\"\n+    runner.invoke(app, [\"serve\"])\n+    mock_run.assert_called_once()\n+    call_kwargs = mock_run.call_args[1]\n+    assert call_kwargs['host'] == '127.0.0.1'\n+    assert call_kwargs['port'] == 8000\n+\n+\n+@patch('uvicorn.run')\n+def test_serve_custom_host_and_port(mock_run):\n+    \"\"\"Test that custom host and port are passed to uvicorn.\"\"\"\n+    runner.invoke(app, [\"serve\", \"--host\", \"0.0.0.0\", \"--port\", \"5000\"])\n+    call_kwargs = mock_run.call_args[1]\n+    assert call_kwargs['host'] == '0.0.0.0'\n+    assert call_kwargs['port'] == 5000\n+\n+\n+@patch('uvicorn.run')\n+def test_serve_address_already_in_use(mock_run):\n+    \"\"\"Test user-friendly error when port is already in use.\"\"\"\n+    mock_run.side_effect = OSError(\"Address already in use\")\n+    result = runner.invoke(app, [\"serve\", \"--port\", \"8000\"])\n+    assert result.exit_code == 1\n+    assert \"already in use\" in result.output\n+\n+\n+@patch('uvicorn.run')\n+def test_serve_permission_denied(mock_run):\n+    \"\"\"Test user-friendly error for privileged port permission denied.\"\"\"\n+    mock_run.side_effect = OSError(\"Permission denied\")\n+    result = runner.invoke(app, [\"serve\", \"--port\", \"80\"])\n+    assert result.exit_code == 1\n+    assert \"Permission denied\" in result.output\n"
