  message: str\n+\n+\n+@app.get(\"/hello\", response_model=HelloResponse)\n+def hello():\n+    \"\"\"Return a simple hello message.\"\"\"\n+    # CORS is intentionally not configured; enable if external client access is needed\n+    return {\"message\": \"hello\"}\n\nmax 5917406diff --git a/pyproject.toml b/pyproject.toml\nindex 23b4060..5ab57d5 100644\n--- a/pyproject.toml\n+++ b/pyproject.toml\n@@ -13,6 +13,14 @@ dependencies = [\n     \"pyyaml>=6\",\n     \"questionary>=2\",\n     \"slack-sdk>=3.19\",\n+    \"fastapi>=0.100\",\n+    \"uvicorn>=0.23\",\n+]\n+\n+[project.optional-dependencies]\n+test = [\n+    \"pytest>=7\",\n+    \"httpx>=0.24\",\n ]\n \n [tool.setuptools.packages.find]\n\ndiff --git a/tests/test_cli_serve.py b/tests/test_cli_serve.py\nindex 0000000..6d9f8ef 100644\n--- a/tests/test_cli_serve.py\n+++ b/tests/test_cli_serve.py\n@@ -0,0 +1,68 @@\n+\"\"\"Tests for the serve CLI command.\"\"\"\n+from unittest.mock import patch, MagicMock\n+\n+import pytest\n+from typer.testing import CliRunner\n+from factory.cli import app\n+\n+\n+runner = CliRunner()\n+\n+\n+def test_serve_invalid_port_negative():\n+    \"\"\"Test that negative port numbers are rejected.\"\"\"\n+    result = runner.invoke(app, [\"serve\", \"--port\", \"-1\"])\n+    assert result.exit_code == 1\n+    # Check result.output (combined stdout+stderr) instead of result.stdout\n+    assert \"Port must be between 0 and 65535\" in result.output\n+\n+\n+def test_serve_invalid_port_too_high():\n+    \"\"\"Test that ports above 65535 are rejected.\"\"\"\n+    result = runner.invoke(app, [\"serve\", \"--port\", \"65536\"])\n+    assert result.exit_code == 1\n+    # Check result.output (combined stdout+stderr) instead of result.stdout\n+    assert \"Port must be between 0 and 65535\" in result.output\n+\n+\n+def test_serve_invalid_host():\n+    \"\"\"Test that invalid hostnames are rejected.\"\"\"\n+    result = runner.invoke(app, [\"serve\", \"--host\", \"invalid@host\"])\n+    assert result.exit_code == 1\n+    assert \"Invalid host\" in result.output\n+\n+\n+@patch(\"factory.cli.uvicorn.run\")\n+def test_serve_valid_port_zero(mock_uvicorn):\n+    \"\"\"Test that port 0 is accepted (auto-selection).\"\"\"\n+    result = runner.invoke(app, [\"serve\", \"--port\", \"0\"])\n+    assert result.exit_code == 0\n+    mock_uvicorn.assert_called_once_with(\n+        \"factory.server:app\", host=\"127.0.0.1\", port=0, reload=False\n+    )\n+\n+\n+@patch(\"factory.cli.uvicorn.run\")\n+def test_serve_valid_port_max(mock_uvicorn):\n+    \"\"\"Test that port 65535 is accepted.\"\"\"\n+    result = runner.invoke(app, [\"serve\", \"--port\", \"65535\"])\n+    assert result.exit_code == 0\n+    mock_uvicorn.assert_called_once_with(\n+        \"factory.server:app\", host=\"127.0.0.1\", port=65535, reload=False\n+    )\n+\n+\n+@patch(\"factory.cli.uvicorn.run\")\n+def test_serve_custom_host(mock_uvicorn):\n+    \"\"\"Test that custom IPv4 host is accepted.\"\"\"\n+    result = runner.invoke(app, [\"serve\", \"--host\", \"0.0.0.0\", \"--port\", \"5000\"])\n+    assert result.exit_code == 0\n+    mock_uvicorn.assert_called_once_with(\n+        \"factory.server:app\", host=\"0.0.0.0\", port=5000, reload=False\n+    )\n+\n+\n+@patch(\"factory.cli.uvicorn.run\")\n+def test_serve_default_host_port(mock_uvicorn):\n+    \"\"\"Test that serve command uses default host and port.\"\"\"\n+    result = runner.invoke(app, [\"serve\"])\n+    assert result.exit_code == 0\n+    mock_uvicorn.assert_called_once_with(\n+        \"factory.server:app\", host=\"127.0.0.1\", port=8000, reload=False\n+    )\n\n@patch(\"factory.cli.uvicorn.run\")\n+def test_serve_ipv6_host(mock_uvicorn):\n+    \"\"\"Test that IPv6 addresses are accepted.\"\"\"\n+    result = runner.invoke(app, [\"serve\", \"--host\", \"::\"])\n+    assert result.exit_code == 0\n+    mock_uvicorn.assert_called_once_with(\n+        \"factory.server:app\", host=\"::\", port=8000, reload=False\n+    )\n\ndiff --git a/tests/test_server.py b/tests/test_server.py\nindex 0000000..054eb83 100644\n--- a/tests/test_server.py\n+++ b/tests/test_server.py\n@@ -0,0 +1,47 @@\n+\"\"\"Tests for the FastAPI server.\"\"\"\n+import pytest\n+from fastapi.testclient import TestClient\n+from factory.server import app\n+\n+\n+@pytest.fixture\n+def client():\n+    \"\"\"FastAPI test client.\"\"\"\n+    return TestClient(app)\n+\n+\n+def test_hello_endpoint(client):\n+    \"\"\"Test that /hello endpoint returns correct JSON.\"\"\"\n+    response = client.get(\"/hello\")\n+    assert response.status_code == 200\n+    assert response.json() == {\"message\": \"hello\"}\n+\n+\n+def test_hello_content_type(client):\n+    \"\"\"Test that /hello endpoint returns JSON content type.\"\"\"\n+    response = client.get(\"/hello\")\n+    assert response.headers[\"content-type\"] == \"application/json\"\n+\n+\n+def test_hello_post_not_allowed(client):\n+    \"\"\"Test that POST requests to /hello are not allowed.\"\"\"\n+    response = client.post(\"/hello\")\n+    assert response.status_code == 405\n+\n+\n+def test_hello_put_not_allowed(client):\n+    \"\"\"Test that PUT requests to /hello are not allowed.\"\"\"\n+    response = client.put(\"/hello\")\n+    assert response.status_code == 405\n+\n+\n+def test_hello_delete_not_allowed(client):\n+    \"\"\"Test that DELETE requests to /hello are not allowed.\"\"\"\n+    response = client.delete(\"/hello\")\n+    assert response.status_code == 405\n+\n+\n+def test_nonexistent_endpoint(client):\n+    \"\"\"Test that nonexistent endpoints return 404.\"\"\"\n+    response = client.get(\"/nonexistent\")\n+    assert response.status_code == 404"
