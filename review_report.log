111111\n--- /dev/null\n+++ b/tests/test_server.py\n@@ -0,0 +1,40 @@\n+\"\"\"Tests for the HTTP API server.\"\"\"\n+import pytest\n+from fastapi.testclient import TestClient\n+from factory.server import app\n+\n+\n+@pytest.fixture\n+def client():\n+    \"\"\"FastAPI TestClient fixture.\"\"\"\n+    return TestClient(app)\n+\n+\n+def test_hello_endpoint_returns_correct_json(client):\n+    \"\"\"Test that /hello returns the correct JSON response.\"\"\"\n+    response = client.get(\"/hello\")\n+    assert response.status_code == 200\n+    assert response.json() == {\"message\": \"Hello from Silverforge Factory\"}\n+\n+\n+def test_hello_endpoint_has_correct_content_type(client):\n+    \"\"\"Test that /hello returns application/json.\"\"\"\n+    response = client.get(\"/hello\")\n+    assert response.headers[\"content-type\"] == \"application/json\"\n+\n+\n+def test_app_title():\n+    \"\"\"Test that the app title is set correctly.\"\"\"\n+    assert app.title == \"Silverforge Factory\"\n+\n+\n+def test_app_version():\n+    \"\"\"Test that the app version is set correctly.\"\"\"\n+    assert app.version == \"0.1.0\"\n+\n+\n+def test_hello_endpoint_method_not_allowed(client):\n+    \"\"\"Test that POST to /hello is not allowed.\"\"\"\n+    response = client.post(\"/hello\")\n+    assert response.status_code == 405\ndiff --git a/tests/test_cli_serve.py b/tests/test_cli_serve.py\nnew file mode 100644\nindex 0000000..1111111\n--- /dev/null\n+++ b/tests/test_cli_serve.py\n@@ -0,0 +1,62 @@\n+\"\"\"Tests for the CLI serve command.\"\"\"\n+import pytest\n+from typer.testing import CliRunner\n+\n+from factory.cli import app as cli_app\n+\n+\n+@pytest.fixture\n+def runner():\n+    \"\"\"Create a CLI test runner.\"\"\"\n+    return CliRunner()\n+\n+\n+def test_serve_invalid_port_negative(runner):\n+    \"\"\"Test that serve command rejects negative port values.\"\"\"\n+    result = runner.invoke(cli_app, [\"serve\", \"--port\", \"-1\"])\n+    assert result.exit_code == 1\n+    assert